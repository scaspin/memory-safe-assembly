      <encoding name="LUTI2_asimdtbl_L5" oneofinclass="2" oneof="2" label="Byte" bitdiffs="op2 == 10 &amp;&amp; op == 1">
        <docvars>
          <docvar key="instr-class" value="advsimd" />
          <docvar key="isa" value="A64" />
          <docvar key="mnemonic" value="LUTI2" />
          <docvar key="simd-luti" value="simd-byte" />
        </docvars>
        <box hibit="23" width="2" name="op2">
          <c></c>
          <c>0</c>
        </box>
        <box hibit="12" width="1" name="op">
          <c>1</c>
        </box>
        <asmtemplate><text>LUTI2  </text><a link="sa_vd" hover="SIMD&amp;FP destination register (field &quot;Rd&quot;)">&lt;Vd&gt;</a><text>.16B, </text><text>{</text><text> </text><a link="sa_vn" hover="SIMD&amp;FP table register (field &quot;Rn&quot;)">&lt;Vn&gt;</a><text>.16B </text><text>}</text><text>, </text><a link="sa_vm" hover="SIMD&amp;FP source register (field &quot;Rm&quot;)">&lt;Vm&gt;</a><text>[</text><a link="sa_index" hover="Vector segment index [0-3] (field &quot;len&quot;)">&lt;index&gt;</a><text>]</text></asmtemplate>
