  <explanations scope="all">
    <explanation enclist="LUTI2_asimdtbl_L5, LUTI2_asimdtbl_L6" symboldefcount="1">
      <symbol link="sa_vd">&lt;Vd&gt;</symbol>
      <account encodedin="Rd">
        <intro>
