<instructionsection id="PACM" title="PACM -- A64" type="instruction">
  <docvars>
    <docvar key="instr-class" value="system" />
    <docvar key="isa" value="A64" />
    <docvar key="mnemonic" value="PACM" />
  </docvars>
  <heading>PACM</heading>
  <desc>
    <brief>
      <para>Pointer authentication modifier</para>
    </brief>
    <authored>
      <para>Pointer authentication modifier. This instruction is used to set the value of PSTATE.PACM to 1.</para>
      <para>If <xref linkend="FEAT_PAuth_LR">FEAT_PAuth_LR</xref> is not implemented, this instruction behaves as a NOP.</para>
    </authored>
  </desc>
  <alias_list howmany="0"></alias_list>
  <classes>
    <iclass name="System" oneof="1" id="iclass_system" no_encodings="1" isa="A64">
      <docvars>
        <docvar key="instr-class" value="system" />
        <docvar key="isa" value="A64" />
        <docvar key="mnemonic" value="PACM" />
      </docvars>
      <iclassintro count="1"></iclassintro>
      <arch_variants>
        <arch_variant name="FEAT_PAuth_LR" feature="FEAT_PAuth_LR" />
      </arch_variants>
      <regdiagram form="32" psname="aarch64/instrs/integer/pac/pacm/PACM_HI_hints">
        <box hibit="31" width="10" settings="10">
          <c>1</c>
