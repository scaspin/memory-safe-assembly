      <encoding name="LUTI4_asimdtbl_L5" oneofinclass="2" oneof="2" label="Byte" bitdiffs="len == x1 &amp;&amp; op == 0">
        <docvars>
          <docvar key="instr-class" value="advsimd" />
          <docvar key="isa" value="A64" />
