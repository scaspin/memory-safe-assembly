        <asmtemplate><text>LUTI4  </text><a link="sa_vd" hover="SIMD&amp;FP destination register (field &quot;Rd&quot;)">&lt;Vd&gt;</a><text>.16B, </text><text>{</text><text> </text><a link="sa_vn" hover="SIMD&amp;FP table register (field &quot;Rn&quot;)">&lt;Vn&gt;</a><text>.16B </text><text>}</text><text>, </text><a link="sa_vm" hover="SIMD&amp;FP source register (field &quot;Rm&quot;)">&lt;Vm&gt;</a><text>[</text><a link="sa_index" hover="Vector segment index [0-1] (field &quot;len&lt;1&gt;&quot;)">&lt;index&gt;</a><text>]</text></asmtemplate>
