      <ps_section howmany="1">
        <ps name="aarch64/instrs/vector/arithmetic/binary/uniform/max-min/fp8/fp16/FAMIN_asimdsamefp16_only" mylink="aarch64.instrs.vector.arithmetic.binary.uniform.max-min.fp8.fp16.FAMIN_asimdsamefp16_only" enclabels="" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_FAMINMAX) then UNDEFINED;
constant integer esize = 16;
integer n = <a link="impl-shared.UInt.1" file="shared_pseudocode.xml" hover="function: integer UInt(bits(N) x)">UInt</a>(Rn);
integer m = <a link="impl-shared.UInt.1" file="shared_pseudocode.xml" hover="function: integer UInt(bits(N) x)">UInt</a>(Rm);
integer d = <a link="impl-shared.UInt.1" file="shared_pseudocode.xml" hover="function: integer UInt(bits(N) x)">UInt</a>(Rd);
constant integer datasize = if Q == '1' then 128 else 64;
integer elements = datasize DIV esize;
boolean ismax = U == '0';</pstext>
