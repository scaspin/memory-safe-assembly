      <ps_section howmany="1">
        <ps name="aarch64/instrs/vector/arithmetic/binary/uniform/max-min/fp8/FAMIN_asimdsame_only" mylink="aarch64.instrs.vector.arithmetic.binary.uniform.max-min.fp8.FAMIN_asimdsame_only" enclabels="" sections="1" secttype="noheading">
