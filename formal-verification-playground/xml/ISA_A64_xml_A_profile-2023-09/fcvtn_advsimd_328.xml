<instructionsection id="FCVTN_advsimd_328" title="FCVTN, FCVTN2 (FP32 to FP8) -- A64" type="instruction">
  <docvars>
    <docvar key="advsimd-only" value="simd-only" />
    <docvar key="advsimd-type" value="simd" />
